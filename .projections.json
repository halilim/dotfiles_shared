{
  "**/*.sh": {
    "alternate": [
      "spec/{dirname}/{basename}_spec.sh",
      "spec/{dirname}/{basename}_spec.zsh",
      "spec/{dirname}/{basename}_spec.bash"
    ]
  },
  "**/bin/*": {
    "alternate": [
      "spec/{dirname}/bin/{basename}_spec.sh",
      "spec/{dirname}/bin/{basename}_spec.zsh"
    ]
  },
  "**/*.rb": {
    "alternate": "spec/{dirname}/{basename}_spec.rb"
  }
}
